# Copy the relevant keys into apps/web/.env.local and packages/db/.env
# Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Supabase database settings: https://supabase.com/dashboard/project/_/settings/database
# Transaction pooler (port 6543) - used by the app at runtime (apps/web, packages/db)
DATABASE_URL=
# Direct connection (port 5432) - used only for running Drizzle migrations (packages/db)
DIRECT_URL=

# Resend (transactional email, e.g. password reset): https://resend.com/api-keys
RESEND_KEY=
# Optional. Defaults to Resend's shared sandbox sender, which only delivers to
# the Resend account's own verified email. Set this once a domain is verified
# at https://resend.com/domains, e.g. "danlimadev <noreply@danlimadev.app>"
RESEND_FROM_EMAIL=
