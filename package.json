{
  "name": "danlimadev",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @danlimadev/db generate",
    "db:migrate": "pnpm --filter @danlimadev/db migrate",
    "db:studio": "pnpm --filter @danlimadev/db studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  }
}
